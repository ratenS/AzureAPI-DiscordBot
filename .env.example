APP_NAME=azure-discord-bot
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-application-id
DISCORD_ADMIN_USER_IDS=123456789012345678

DATABASE_URL=postgresql+psycopg://postgres:postgres@azure-discord-postgres:5432/azure_discord_bot

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment
AZURE_OPENAI_IMAGE_DEPLOYMENT=your-image-deployment
AZURE_OPENAI_VIDEO_DEPLOYMENT=your-sora-2-video-deployment
AZURE_OPENAI_VIDEO_SIZE=1280x720
AZURE_OPENAI_VIDEO_SECONDS=4
AZURE_OPENAI_VIDEO_POLL_INTERVAL_SECONDS=20
AZURE_OPENAI_VIDEO_POLL_MAX_ATTEMPTS=18
AZURE_OPENAI_VIDEO_DOWNLOAD_ENABLED=true
AZURE_OPENAI_SPEECH_DEPLOYMENT=your-speech-deployment
AZURE_OPENAI_SPEECH_VOICE=alloy
AZURE_OPENAI_REALTIME_DEPLOYMENT=your-gpt-realtime-deployment
SPEECH_KEY=your-azure-speech-key
SPEECH_REGION=your-azure-speech-region
VOICE_CHAT_SYNTHESIS_VOICE=en-US-AvaMultilingualNeural
VOICE_CHAT_REALTIME_VOICE=alloy
VOICE_CHAT_REALTIME_VAD_TYPE=server_vad
VOICE_CHAT_REALTIME_VAD_THRESHOLD=0.5
VOICE_CHAT_REALTIME_PREFIX_PADDING_MS=300
VOICE_CHAT_REALTIME_SILENCE_DURATION_MS=200
VOICE_CHAT_REALTIME_CHUNK_MS=100
VOICE_CHAT_REALTIME_SAMPLE_RATE=24000
VOICE_CHAT_STOP_PHRASES=stop,goodbye

ALLOW_DMS=true
DEFAULT_RAW_LOG_RETENTION_DAYS=30
MEMORY_SYNC_HEURISTICS_ENABLED=true
MAX_PROMPT_CHARS=4000
RATE_LIMIT_REQUESTS_PER_MINUTE=10
BOT_PERSONA=You are a neutral, helpful assistant.
SYSTEM_PROMPT_BASE=Follow server policy, be concise, and avoid unsafe or disallowed content.
